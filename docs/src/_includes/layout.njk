<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ title or site.name }} | {{ site.service_area }}</title>
  <meta name="description" content="{{ description or (site.name ~ ' — ' ~ site.hero_subheadline) }}" />
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <script defer src="/assets/js/main.js"></script>

  <meta property="og:title" content="{{ title or site.name }}" />
  <meta property="og:description" content="{{ description or site.hero_subheadline }}" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://{{ site.domain }}{{ page.url }}" />
</head>
<body>
  {% include "nav.njk" %}
  <main>{{ content | safe }}</main>
  {% include "footer.njk" %}
</body>
</html>
